# Backend API base
VITE_API_BASE=https://serene-api.shapeecloud.com/v1

# Google Identity Services
# Add http://localhost:5173 and http://127.0.0.1:5173
# to Authorized JavaScript origins in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=

# Sign in with Apple for Web
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=
VITE_APPLE_SCOPE=name email
